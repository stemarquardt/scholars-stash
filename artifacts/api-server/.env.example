DATABASE_URL=postgresql://localhost/edu_link_hub
ANTHROPIC_API_KEY=your-anthropic-api-key-here
PORT=8080
NODE_ENV=development

# Restrict CORS to your frontend's origin (in production: https://yourdomain.com)
CORS_ORIGIN=http://localhost:5173

# ── OAuth Providers ────────────────────────────────────────────────────────────
# Each provider is optional — only configure what you want to enable.
# The login page will only show buttons for configured providers.

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
# Authorized redirect URI registered in Google Cloud Console:
GOOGLE_CALLBACK_URL=http://localhost:5173/api/callback/google

# Facebook / Meta OAuth (https://developers.facebook.com/apps/)
# FACEBOOK_APP_ID=your-facebook-app-id-here
# FACEBOOK_APP_SECRET=your-facebook-app-secret-here
# FACEBOOK_CALLBACK_URL=http://localhost:5173/api/callback/facebook

# Discord OAuth (https://discord.com/developers/applications)
# DISCORD_CLIENT_ID=your-discord-client-id-here
# DISCORD_CLIENT_SECRET=your-discord-client-secret-here
# DISCORD_CALLBACK_URL=http://localhost:5173/api/callback/discord
